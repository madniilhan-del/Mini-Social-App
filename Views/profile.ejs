<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Document</title>
   <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body>
 
   <div class="w-full min-h-screen bg-zinc-900 text-white p-3">
    <div class=" w-full flex justify-end">
      <a class="bg-red-500 text-sm rounded-md px-3 py-2 mb-5 inline-block" href="/logout">Log Out</a>

    </div>

    
       <h3 class="text-3xl mb-10"><span class="font-light"> Hello , </span>   <%= user.name %> 🧑‍🏫 </h3>

       <h5 class="mb-5">You can Create a New Post . </h5>
        
       <form class="" method="post" action="/post">
          
         <textarea class="w-1/3 mb-4 resize-none p-5  bg-transparent rounded-md border-2 border-zinc-800 outline-none block" placeholder="What's on Your Mind" name="content" ></textarea>
  
         <input class="block px-3 py-2 bg-blue-500 w-40 rounded-md cursor-pointer " value="Create New Post" type="submit">
          
       </form> 


       <div class="posts mt-20  ">


        <h3 class="text-zinc-400">Your Post .</h3>

               <div class="postContainer mt-5">
                
                 <% user.posts.reverse().forEach(function(post){%>

                   
                <div class="post w-1/3 mb-3 bg-zinc-700 p-4 border-[1px] border-zinc-800">
                  <h4 class="text-blue-500 mb-2"><%= user.username %></h4>
                  <p class="text-sm tracking-tight"><%= post.content %></p>

                  <div class="btns flex mt-5 gap-5">
                     
                     <a class="text-blue-500" href="/like/<%= post.id%>">Like</a>
                     <a class="text-zinc-700" href="">edit</a>

                  </div>

                </div>

               

                 <%}) %>
                 

               </div>

       </div>
        


   </div>
  


</body>
</html>