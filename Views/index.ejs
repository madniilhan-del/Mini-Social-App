<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Document</title>
   <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body>
 



   <div class="w-full min-h-screen bg-zinc-900 text-white p-6">
         <div class="w-full flex  justify-end">
            <a class="bg-blue-500 px-4 py-2 rounded-md text-sm" href="/login"> Log In</a>

         </div>
          
 
       <h3 class="text-3xl mb-10"> Create Account 👱 </h3>

    <form action="/register" method="post">
      
       <input type="text"  class="px-5 py-3 bg-transparent outline-none border-2 cursor-pointer  border-zinc-800 rounded-md" placeholder="Enter Username" name="username" id="">
       <input type="text" class="px-5 py-3 bg-transparent outline-none border-2 cursor-pointer  border-zinc-800 rounded-md"  placeholder="Enter name" name="name" id="" value="">
        <input type="number" class="px-5 py-3 bg-transparent outline-none cursor-pointer  border-2 border-zinc-800 rounded-md"  placeholder="Enter Age" name="age" id="">
        <input type="text" class="px-5 py-3 bg-transparent outline-none cursor-pointer  border-2 border-zinc-800 rounded-md"  name="email" placeholder="Enter Email" id="">
        <input type="password" class="px-5 py-3 cursor-pointer  bg-transparent outline-none border-2 border-zinc-800 rounded-md"  name="password" placeholder="Enter password" autocomplete="new-password" required id="">
        <input type="submit" class="px-2 text-sm py-2 bg-blue-500 cursor-pointer  rounded-md "  name="" value="Create Account" id=""> 


 

    </form>
     


   </div>
  


</body>
</html>